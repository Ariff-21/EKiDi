<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET"/>

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.EKiDi">

        <activity
            android:name=".ui.splash.SplashActivity"
            android:theme="@style/Theme.EKiDi.Splash"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>

        <activity android:name=".ui.auth.LoginActivity"/>
        <activity android:name=".ui.auth.RegisterActivity"/>
        <activity android:name=".ui.home.HomeActivity"/>
        <activity android:name=".ui.literasi.LiterasiActivity"/>
        <activity android:name=".ui.literasi.DetailLiterasiActivity"/>
        <activity android:name=".ui.game.GameActivity"/>
        <activity android:name=".ui.misi.MisiActivity"/>
        <activity android:name=".ui.pencapaian.PencapaianActivity"/>
        <activity android:name=".ui.profil.ProfilActivity"/>
        <activity android:name=".ui.literasi.MateriActivity"/>
        <activity android:name=".ui.literasi.KuisActivity"/>
        <activity android:name=".ui.game.DragDropGameActivity"
            android:screenOrientation="portrait"/>

    </application>

</manifest>