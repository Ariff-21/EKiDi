<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="90dp"
        android:background="@drawable/bg_splash_gradient"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@android:drawable/ic_media_previous"
            android:background="@drawable/circle_settings_bg"
            android:padding="8dp"
            app:tint="#FFFFFF" />

        <TextView
            android:id="@+id/tvJudulMateri"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="📖 Materi"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_marginStart="12dp"/>

    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="75dp"
        android:layout_marginBottom="64dp"
        android:padding="16dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Banner pendampingan ortu -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FEF3C7">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="12dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="👨‍👧"
                        android:textSize="28sp"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Bacakan materi ini bersama Ayah/Bunda ya! 😊"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="@color/icon_yellow"
                        android:layout_marginStart="10dp"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Ikon & Judul Topik -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/tvIkonTopik"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:text="💻"
                    android:textSize="44sp"
                    android:gravity="center"
                    android:background="@drawable/circle_menu_blue"/>

                <TextView
                    android:id="@+id/tvNamaTopik"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pengenalan Perangkat Digital"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:gravity="center"
                    android:layout_marginTop="10dp"/>

            </LinearLayout>

            <!-- Konten Materi -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/bg_card">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📚 Apa yang akan kita pelajari?"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@color/purple_primary"
                        android:layout_marginBottom="10dp"/>

                    <TextView
                        android:id="@+id/tvKontenMateri"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textSize="14sp"
                        android:textColor="@color/text_primary"
                        android:lineSpacingExtra="6dp"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Poin Penting -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#EDE9FE">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="💡 Ingat ya!"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@color/purple_primary"
                        android:layout_marginBottom="8dp"/>

                    <TextView
                        android:id="@+id/tvPoinPenting"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textSize="13sp"
                        android:textColor="@color/text_primary"
                        android:lineSpacingExtra="6dp"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Pilih Level Kuis -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🎯 Pilih Level Kuis"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="10dp"/>

            <!-- Level 1 -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardLevel1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/card_green">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="14dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:text="😊"
                        android:textSize="26sp"
                        android:gravity="center"
                        android:background="@drawable/circle_menu_green"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Level 1 — Benar atau Salah"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="@color/icon_green"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="5 soal • +10 poin per soal benar"
                            android:textSize="11sp"
                            android:textColor="@color/text_secondary"/>

                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvStatusLevel1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Mulai"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:background="@drawable/bg_button_primary"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="6dp"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Level 2 -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardLevel2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/card_blue">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="14dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:text="🤔"
                        android:textSize="26sp"
                        android:gravity="center"
                        android:background="@drawable/circle_menu_blue"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Level 2 — 4 Pilihan Gambar"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="@color/icon_blue"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="5 soal • +15 poin per soal benar"
                            android:textSize="11sp"
                            android:textColor="@color/text_secondary"/>

                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvStatusLevel2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔒"
                        android:textSize="18sp"
                        android:textColor="@color/text_hint"
                        android:paddingHorizontal="12dp"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Level 3 -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardLevel3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/card_purple">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="14dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:text="🧠"
                        android:textSize="26sp"
                        android:gravity="center"
                        android:background="@drawable/circle_menu_purple"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Level 3 — 4 Pilihan Teks"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="@color/icon_purple"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="5 soal • +20 poin per soal benar"
                            android:textSize="11sp"
                            android:textColor="@color/text_secondary"/>

                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvStatusLevel3"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔒"
                        android:textSize="18sp"
                        android:textColor="@color/text_hint"
                        android:paddingHorizontal="12dp"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_gravity="bottom"
        android:background="@color/bg_card"
        app:menu="@menu/bottom_nav_menu"
        app:itemIconTint="@color/bottom_nav_color"
        app:itemTextColor="@color/bottom_nav_color"
        app:labelVisibilityMode="labeled"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>