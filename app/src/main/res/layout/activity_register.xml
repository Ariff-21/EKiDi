<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp">

        <!-- Dekorasi Background -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🎈"
            android:textSize="32sp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="20dp"
            android:alpha="0.4"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🎨"
            android:textSize="28sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginBottom="20dp"
            android:alpha="0.3"/>

        <!-- Judul -->
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Daftar Akun Baru 🌈"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="@color/purple_primary"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginTop="32dp"/>

        <TextView
            android:id="@+id/tvSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ayo bergabung dan belajar bersama! ✨"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            app:layout_constraintTop_toBottomOf="@id/tvTitle"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginTop="6dp"/>

        <!-- Card Form Register -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardRegister"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/bg_card"
            app:layout_constraintTop_toBottomOf="@id/tvSubtitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Pilih Peran -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Aku adalah seorang:"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="12dp"
                    android:layout_marginStart="4dp"/>

                <LinearLayout
                    android:id="@+id/layoutRole"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="24dp">

                    <TextView
                        android:id="@+id/btnRoleAnak"
                        android:layout_width="0dp"
                        android:layout_height="64dp"
                        android:layout_weight="1"
                        android:text="👦\nAnak"
                        android:gravity="center"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:background="@drawable/bg_role_selected"
                        android:textColor="@color/purple_primary"
                        android:layout_marginEnd="6dp"
                        android:lineSpacingExtra="4dp"/>

                    <TextView
                        android:id="@+id/btnRoleOrtu"
                        android:layout_width="0dp"
                        android:layout_height="64dp"
                        android:layout_weight="1"
                        android:text="👨\nOrtu"
                        android:gravity="center"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:background="@drawable/bg_role_unselected"
                        android:textColor="@color/text_secondary"
                        android:layout_marginHorizontal="3dp"
                        android:lineSpacingExtra="4dp"/>

                    <TextView
                        android:id="@+id/btnRoleGuru"
                        android:layout_width="0dp"
                        android:layout_height="64dp"
                        android:layout_weight="1"
                        android:text="👩‍🏫\nGuru"
                        android:gravity="center"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:background="@drawable/bg_role_unselected"
                        android:textColor="@color/text_secondary"
                        android:layout_marginStart="6dp"
                        android:lineSpacingExtra="4dp"/>

                </LinearLayout>

                <!-- Input Nama -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="👤 Nama Lengkap"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="8dp"
                    android:layout_marginStart="8dp"/>

                <EditText
                    android:id="@+id/etNama"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:hint="Siapa namamu?"
                    android:textSize="14sp"
                    android:background="@drawable/bg_input_field"
                    android:paddingHorizontal="18dp"
                    android:inputType="textPersonName"
                    android:singleLine="true"
                    android:elevation="2dp"/>

                <Space android:layout_width="0dp" android:layout_height="16dp"/>

                <!-- Input Username -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📧 Email"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="8dp"
                    android:layout_marginStart="8dp"/>

                <EditText
                    android:id="@+id/etUsername"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:hint="Email kamu"
                    android:textSize="14sp"
                    android:background="@drawable/bg_input_field"
                    android:paddingHorizontal="18dp"
                    android:inputType="textEmailAddress"
                    android:singleLine="true"
                    android:elevation="2dp"/>

                <Space android:layout_width="0dp" android:layout_height="16dp"/>

                <!-- Input Umur (khusus role Anak) -->
                <TextView
                    android:id="@+id/labelUmur"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🎂 Umur"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="8dp"
                    android:layout_marginStart="8dp"
                    android:visibility="visible"/>

                <EditText
                    android:id="@+id/etUmur"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:hint="Berapa umurmu?"
                    android:textSize="14sp"
                    android:background="@drawable/bg_input_field"
                    android:paddingHorizontal="18dp"
                    android:inputType="number"
                    android:singleLine="true"
                    android:visibility="visible"
                    android:elevation="2dp"/>

                <Space android:id="@+id/spaceUmur" android:layout_width="0dp"
                    android:layout_height="16dp" android:visibility="visible"/>

                <!-- Input Password -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔑 Password"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="8dp"
                    android:layout_marginStart="8dp"/>

                <EditText
                    android:id="@+id/etPassword"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:hint="Buat password aman"
                    android:textSize="14sp"
                    android:background="@drawable/bg_input_field"
                    android:paddingHorizontal="18dp"
                    android:inputType="textPassword"
                    android:singleLine="true"
                    android:elevation="2dp"/>

                <Space android:layout_width="0dp" android:layout_height="16dp"/>

                <!-- Konfirmasi Password -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔄 Ulangi Password"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="8dp"
                    android:layout_marginStart="8dp"/>

                <EditText
                    android:id="@+id/etConfirmPassword"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:hint="Tulis ulang password"
                    android:textSize="14sp"
                    android:background="@drawable/bg_input_field"
                    android:paddingHorizontal="18dp"
                    android:inputType="textPassword"
                    android:singleLine="true"
                    android:elevation="2dp"/>

                <Space android:layout_width="0dp" android:layout_height="28dp"/>

                <!-- Tombol Daftar -->
                <Button
                    android:id="@+id/btnRegister"
                    android:layout_width="match_parent"
                    android:layout_height="58dp"
                    android:text="Ayo Daftar! ✨"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/bg_button_primary"
                    android:stateListAnimator="@null"
                    android:elevation="4dp"/>

                <Space android:layout_width="0dp" android:layout_height="16dp"/>

                <!-- Link ke Login -->
                <TextView
                    android:id="@+id/tvGoToLogin"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sudah punya akun? Masuk di sini"
                    android:textSize="13sp"
                    android:textColor="@color/purple_primary"
                    android:textStyle="bold"
                    android:layout_gravity="center"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Error message -->
        <TextView
            android:id="@+id/tvError"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="13sp"
            android:textColor="@color/error"
            android:gravity="center"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/cardRegister"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginTop="12dp"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>