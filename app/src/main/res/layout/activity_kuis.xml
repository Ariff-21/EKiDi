<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main"
    android:padding="20dp">

    <!-- Header Kuis -->
    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="@drawable/circle_avatar_bg"
        android:src="@android:drawable/ic_menu_revert"
        app:tint="@color/purple_primary"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <TextView
        android:id="@+id/tvJudulKuis"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🎯 Kuis Seru"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary"
        app:layout_constraintTop_toTopOf="@id/btnBack"
        app:layout_constraintBottom_toBottomOf="@id/btnBack"
        app:layout_constraintStart_toEndOf="@id/btnBack"
        android:layout_marginStart="16dp"/>

    <TextView
        android:id="@+id/tvSkorKuis"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="⭐ 0"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@color/gold"
        app:layout_constraintTop_toTopOf="@id/btnBack"
        app:layout_constraintBottom_toBottomOf="@id/btnBack"
        app:layout_constraintEnd_toEndOf="parent"
        android:background="@drawable/bg_level_badge"
        android:paddingHorizontal="16dp"
        android:paddingVertical="4dp"/>

    <!-- Progress Bar -->
    <ProgressBar
        android:id="@+id/progressKuis"
        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
        android:layout_width="match_parent"
        android:layout_height="12dp"
        android:layout_marginTop="24dp"
        android:progressDrawable="@drawable/bg_progress_drawable"
        app:layout_constraintTop_toBottomOf="@id/btnBack"/>

    <TextView
        android:id="@+id/tvNomorSoal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Soal 1 dari 5"
        android:textSize="14sp"
        android:textColor="@color/text_secondary"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/progressKuis"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- Card Soal -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardSoal"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="8dp"
        app:cardCornerRadius="32dp"
        app:cardElevation="4dp"
        app:layout_constraintTop_toBottomOf="@id/tvNomorSoal"
        app:layout_constraintBottom_toTopOf="@id/btnLanjut">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                android:gravity="center_horizontal">

                <TextView
                    android:id="@+id/tvEmoji"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:text="💻"
                    android:textSize="50sp"
                    android:gravity="center"
                    android:background="@drawable/circle_menu_blue"
                    android:elevation="2dp"/>

                <TextView
                    android:id="@+id/tvPertanyaan"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Apakah ini pertanyaan?"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:gravity="center"/>

                <!-- Drop Zone for Drag & Drop -->
                <FrameLayout
                    android:id="@+id/dropZone"
                    android:layout_width="match_parent"
                    android:layout_height="90dp"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/bg_drop_zone"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/tvDropHint"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="Tarik jawaban ke sini"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"/>
                </FrameLayout>

                <!-- Layout Jawaban (Menggunakan ChipGroup agar otomatis pindah baris jika penuh) -->
                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/layoutJawaban"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    app:chipSpacingHorizontal="8dp"
                    app:chipSpacingVertical="8dp"/>

                <TextView
                    android:id="@+id/tvFeedback"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Feedback"
                    android:textSize="15sp"
                    android:textStyle="italic"
                    android:gravity="center"
                    android:visibility="gone"
                    android:paddingBottom="16dp"/>

            </LinearLayout>
        </ScrollView>
    </androidx.cardview.widget.CardView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnLanjut"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Lanjutkan ➡"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textAllCaps="false"
        app:cornerRadius="30dp"
        app:backgroundTint="@color/purple_primary"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginBottom="4dp"
        android:visibility="gone"/>

</androidx.constraintlayout.widget.ConstraintLayout>
