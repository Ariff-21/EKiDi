<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="90dp"
        android:background="@drawable/bg_splash_gradient"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@android:drawable/ic_media_previous"
            android:background="@drawable/circle_settings_bg"
            android:padding="8dp"
            app:tint="#FFFFFF" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="👤 Profil Saya"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_marginStart="12dp"/>

    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="75dp"
        android:padding="16dp"
        android:clipToPadding="false"
        android:paddingBottom="100dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Card Avatar & Nama -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="@color/bg_card">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="24dp">

                    <!-- Avatar -->
                    <TextView
                        android:id="@+id/tvAvatar"
                        android:layout_width="90dp"
                        android:layout_height="90dp"
                        android:text="🐶"
                        android:textSize="52sp"
                        android:gravity="center"
                        android:background="@drawable/circle_avatar_bg_large"/>

                    <Button
                        android:id="@+id/btnGantiAvatar"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:text="Ganti Avatar"
                        android:textSize="11sp"
                        android:textColor="@color/purple_primary"
                        android:background="@drawable/bg_role_selected"
                        android:stateListAnimator="@null"
                        android:paddingHorizontal="16dp"
                        android:layout_marginTop="8dp"/>

                    <!-- Nama -->
                    <TextView
                        android:id="@+id/tvNamaProfil"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Pengguna"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:layout_marginTop="12dp"/>

                    <!-- Role Badge -->
                    <TextView
                        android:id="@+id/tvRoleBadge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="👦 Anak"
                        android:textSize="12sp"
                        android:textColor="@color/purple_primary"
                        android:background="@drawable/bg_level_badge"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="4dp"
                        android:layout_marginTop="6dp"/>

                    <!-- Level & Poin -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="12dp">

                        <TextView
                            android:id="@+id/tvLevelProfil"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="⭐ Level 1"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="@color/gold"
                            android:background="@drawable/bg_level_badge"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="4dp"/>

                        <TextView
                            android:id="@+id/tvPoinProfil"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0 Poin"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_secondary"
                            android:background="@drawable/bg_role_unselected"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="4dp"
                            android:layout_marginStart="8dp"/>

                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Pilih Avatar -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardPilihAvatar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:visibility="gone"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/bg_card">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Pilih Avatar Kamu"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:layout_marginBottom="10dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center">

                        <TextView android:id="@+id/avatar1"
                            android:layout_width="52dp" android:layout_height="52dp"
                            android:text="🐶" android:textSize="30sp"
                            android:gravity="center" android:layout_margin="6dp"
                            android:background="@drawable/bg_role_selected"/>

                        <TextView android:id="@+id/avatar2"
                            android:layout_width="52dp" android:layout_height="52dp"
                            android:text="🐱" android:textSize="30sp"
                            android:gravity="center" android:layout_margin="6dp"
                            android:background="@drawable/bg_role_unselected"/>

                        <TextView android:id="@+id/avatar3"
                            android:layout_width="52dp" android:layout_height="52dp"
                            android:text="🐻" android:textSize="30sp"
                            android:gravity="center" android:layout_margin="6dp"
                            android:background="@drawable/bg_role_unselected"/>

                        <TextView android:id="@+id/avatar4"
                            android:layout_width="52dp" android:layout_height="52dp"
                            android:text="🦊" android:textSize="30sp"
                            android:gravity="center" android:layout_margin="6dp"
                            android:background="@drawable/bg_role_unselected"/>

                        <TextView android:id="@+id/avatar5"
                            android:layout_width="52dp" android:layout_height="52dp"
                            android:text="🐼" android:textSize="30sp"
                            android:gravity="center" android:layout_margin="6dp"
                            android:background="@drawable/bg_role_unselected"/>

                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Info Akun -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📋 Informasi Akun"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="10dp"/>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/bg_card">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Username -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingVertical="10dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="👤"
                            android:textSize="18sp"/>

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Username"
                            android:textSize="13sp"
                            android:textColor="@color/text_secondary"
                            android:layout_marginStart="12dp"/>

                        <TextView
                            android:id="@+id/tvUsername"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="-"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary"/>

                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/divider"/>

                    <!-- Peran -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingVertical="10dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🎭"
                            android:textSize="18sp"/>

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Peran"
                            android:textSize="13sp"
                            android:textColor="@color/text_secondary"
                            android:layout_marginStart="12dp"/>

                        <TextView
                            android:id="@+id/tvPeran"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="-"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary"/>

                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/divider"/>

                    <!-- Level -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingVertical="10dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="⭐"
                            android:textSize="18sp"/>

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Level"
                            android:textSize="13sp"
                            android:textColor="@color/text_secondary"
                            android:layout_marginStart="12dp"/>

                        <TextView
                            android:id="@+id/tvLevelInfo"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="-"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary"/>

                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/divider"/>

                    <!-- Total Poin -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingVertical="10dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="💰"
                            android:textSize="18sp"/>

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Total Poin"
                            android:textSize="13sp"
                            android:textColor="@color/text_secondary"
                            android:layout_marginStart="12dp"/>

                        <TextView
                            android:id="@+id/tvTotalPoin"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="-"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary"/>

                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Pengaturan -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⚙️ Pengaturan"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="10dp"/>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/bg_card">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <!-- Tentang Aplikasi -->
                    <LinearLayout
                        android:id="@+id/menuTentang"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ℹ️"
                            android:textSize="18sp"/>

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Tentang Aplikasi"
                            android:textSize="13sp"
                            android:textColor="@color/text_primary"
                            android:layout_marginStart="12dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="▶"
                            android:textSize="12sp"
                            android:textColor="@color/text_hint"/>

                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/divider"/>

                    <!-- Keluar -->
                    <LinearLayout
                        android:id="@+id/menuLogout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🚪"
                            android:textSize="18sp"/>

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Keluar"
                            android:textSize="13sp"
                            android:textColor="@color/error"
                            android:textStyle="bold"
                            android:layout_marginStart="12dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="▶"
                            android:textSize="12sp"
                            android:textColor="@color/error"/>

                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_gravity="bottom"
        android:background="@color/bg_card"
        app:menu="@menu/bottom_nav_menu"
        app:itemIconTint="@color/bottom_nav_color"
        app:itemTextColor="@color/bottom_nav_color"
        app:labelVisibilityMode="labeled"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>