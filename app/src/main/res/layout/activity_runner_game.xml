<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_main">

    <!-- Header HUD -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical"
        android:background="@drawable/bg_splash_gradient">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_revert"
            android:background="@drawable/circle_settings_bg"
            android:padding="8dp"
            app:tint="#FFFFFF"
            android:layout_marginEnd="12dp"
            android:contentDescription="Kembali"/>

        <!-- Nyawa -->
        <TextView
            android:id="@+id/tvNyawa"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="❤️❤️❤️"
            android:textSize="20sp"/>

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1"/>

        <!-- Level -->
        <TextView
            android:id="@+id/tvLevelInfo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Level Mudah"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/purple_primary"
            android:background="@drawable/bg_level_badge"
            android:paddingHorizontal="14dp"
            android:paddingVertical="6dp"/>

        <!-- Skor -->
        <TextView
            android:id="@+id/tvSkorGame"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="⭐ 0"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:gravity="end"
            android:shadowColor="#40000000"
            android:shadowDx="1"
            android:shadowDy="1"
            android:shadowRadius="2"/>

    </LinearLayout>

    <!-- Progress rintangan -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp"
        android:paddingVertical="8dp"
        android:gravity="center_vertical"
        android:background="#F8FAFC">

        <TextView
            android:id="@+id/tvProgressRintangan"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Rintangan: 0/5"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="@color/text_secondary"/>

        <ProgressBar
            android:id="@+id/progressRintangan"
            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
            android:layout_width="0dp"
            android:layout_height="10dp"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:max="100"
            android:progress="0"
            android:progressDrawable="@drawable/bg_progress_drawable"/>

    </LinearLayout>

    <!-- Area Game Canvas -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- Game Canvas -->
        <com.example.ekidi.ui.game.GameCanvasView
            android:id="@+id/gameCanvas"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>

        <!-- Overlay Soal (muncul saat ketemu rintangan) -->
        <LinearLayout
            android:id="@+id/layoutSoal"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:background="#CC000000"
            android:padding="20dp"
            android:visibility="gone">

            <!-- Timer countdown -->
            <TextView
                android:id="@+id/tvTimer"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:text="15"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:gravity="center"
                android:background="@drawable/circle_menu_blue"
                android:layout_marginBottom="20dp"
                android:elevation="8dp"/>

            <!-- Emoji rintangan -->
            <TextView
                android:id="@+id/tvEmojiRintangan"
                android:layout_width="96dp"
                android:layout_height="96dp"
                android:text="💻"
                android:textSize="60sp"
                android:gravity="center"
                android:background="@color/bg_card"
                android:elevation="4dp"
                android:layout_marginBottom="16dp"/>

            <!-- Pertanyaan -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="24dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardElevation="8dp">

                <TextView
                    android:id="@+id/tvPertanyaanGame"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Pertanyaan muncul di sini"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#1F2937"
                    android:gravity="center"
                    android:padding="24dp"
                    android:lineSpacingExtra="4dp"/>

            </androidx.cardview.widget.CardView>

            <!-- Pilihan Jawaban -->
            <GridLayout
                android:id="@+id/gridJawaban"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:rowCount="2"
                android:useDefaultMargins="false"/>

        </LinearLayout>

        <!-- Overlay Game Over -->
        <androidx.cardview.widget.CardView
            android:id="@+id/layoutGameOver"
            android:layout_width="300dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            app:cardCornerRadius="32dp"
            app:cardElevation="16dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="32dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="😢"
                    android:textSize="80sp"
                    android:gravity="center"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ayo Coba Lagi!"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="@color/error"
                    android:layout_marginTop="12dp"/>

                <TextView
                    android:id="@+id/tvSkorGameOver"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Skor: 0"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/gold"
                    android:layout_marginTop="8dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnMainLagi"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="🔄 Main Lagi"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textAllCaps="false"
                    app:cornerRadius="28dp"
                    android:backgroundTint="@color/purple_primary"
                    android:layout_marginTop="24dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnKeluar"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="🏠 Kembali"
                    android:textSize="16sp"
                    android:textAllCaps="false"
                    app:cornerRadius="28dp"
                    android:layout_marginTop="12dp"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Overlay Menang -->
        <androidx.cardview.widget.CardView
            android:id="@+id/layoutMenang"
            android:layout_width="320dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            app:cardCornerRadius="32dp"
            app:cardElevation="16dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="32dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🎉"
                    android:textSize="80sp"
                    android:gravity="center"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Kamu Hebat!"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:textColor="@color/success"
                    android:gravity="center"
                    android:layout_marginTop="12dp"/>

                <TextView
                    android:id="@+id/tvSkorMenang"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Skor: 0"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/gold"
                    android:layout_marginTop="8dp"/>

                <TextView
                    android:id="@+id/tvBintangMenang"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⭐⭐⭐"
                    android:textSize="40sp"
                    android:layout_marginTop="12dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSelesai"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="🏠 Selesai"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textAllCaps="false"
                    app:cornerRadius="28dp"
                    android:backgroundTint="@color/purple_primary"
                    android:layout_marginTop="24dp"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </FrameLayout>

</LinearLayout>
