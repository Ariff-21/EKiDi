<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/layoutHeader"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:background="@drawable/bg_splash_gradient"
        android:orientation="horizontal"
        android:padding="20dp"
        android:gravity="center_vertical">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@android:drawable/ic_menu_revert"
            android:background="@drawable/circle_settings_bg"
            android:padding="10dp"
            app:tint="#FFFFFF" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🧭 Petualangan Misi"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_marginStart="16dp"/>

        <TextView
            android:id="@+id/tvStreak"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔥 0 Hari"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:background="@drawable/bg_level_badge"
            android:paddingHorizontal="12dp"
            android:paddingVertical="4dp"/>

    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="85dp"
        android:padding="20dp"
        android:clipToPadding="false"
        android:paddingBottom="110dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Banner Streak -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="28dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="@color/sunny_yellow_light">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="20dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔥"
                        android:textSize="44sp"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Semangat Belajar!"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/sunny_yellow"/>

                        <TextView
                            android:id="@+id/tvStreakDesc"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Ayo selesaikan misi hari ini!"
                            android:textSize="13sp"
                            android:textColor="@color/text_secondary"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvStreakAngka"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="32sp"
                        android:textStyle="bold"
                        android:textColor="@color/sunny_yellow"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Misi Harian -->
            <TextView
                android:id="@+id/tvMisiHariIni"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📅 Misi Hari Ini"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="16dp"
                android:layout_marginStart="4dp"/>

            <androidx.cardview.widget.CardView
                android:id="@+id/cardMisiHarian1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/bg_card">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:text="📖"
                        android:textSize="28sp"
                        android:gravity="center"
                        android:background="@drawable/circle_menu_blue"
                        android:elevation="4dp"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Baca 1 Materi"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Hadiah: +20 poin ⭐"
                            android:textSize="12sp"
                            android:textColor="@color/sky_blue"
                            android:textStyle="bold"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnClaimHarian1"
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:text="Klaim"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textAllCaps="false"
                        app:cornerRadius="24dp"
                        android:backgroundTint="@color/sky_blue"
                        android:visibility="gone"/>

                    <TextView
                        android:id="@+id/tvStatusMisiHarian1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Mulai"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:background="@drawable/bg_button_primary"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="8dp"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/cardMisiHarian2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/bg_card">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:text="🎮"
                        android:textSize="28sp"
                        android:gravity="center"
                        android:background="@drawable/circle_menu_green"
                        android:elevation="4dp"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Main Game"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Hadiah: +15 poin ⭐"
                            android:textSize="12sp"
                            android:textColor="@color/leaf_green"
                            android:textStyle="bold"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnClaimHarian2"
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:text="Klaim"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textAllCaps="false"
                        app:cornerRadius="24dp"
                        android:backgroundTint="@color/leaf_green"
                        android:visibility="gone"/>

                    <TextView
                        android:id="@+id/tvStatusMisiHarian2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Mulai"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:background="@drawable/bg_button_primary"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="8dp"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/cardMisiHarian3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/bg_card">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:text="📝"
                        android:textSize="28sp"
                        android:gravity="center"
                        android:background="@drawable/circle_menu_purple"
                        android:elevation="4dp"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Selesaikan 1 Kuis"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Hadiah: +25 poin ⭐"
                            android:textSize="12sp"
                            android:textColor="@color/soft_purple"
                            android:textStyle="bold"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnClaimHarian3"
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:text="Klaim"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textAllCaps="false"
                        app:cornerRadius="24dp"
                        android:backgroundTint="@color/soft_purple"
                        android:visibility="gone"/>

                    <TextView
                        android:id="@+id/tvStatusMisiHarian3"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Mulai"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:background="@drawable/bg_button_primary"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="8dp"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Misi Mingguan -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📆 Misi Mingguan"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp"
                android:layout_marginStart="4dp"/>

            <androidx.cardview.widget.CardView
                android:id="@+id/cardMisiMingguan1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/bg_card">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:text="🏆"
                        android:textSize="28sp"
                        android:gravity="center"
                        android:background="@drawable/circle_menu_yellow"
                        android:elevation="4dp"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Misi Mingguan"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Hadiah: +100 poin 🌟"
                            android:textSize="12sp"
                            android:textColor="@color/sunny_yellow"
                            android:textStyle="bold"
                            android:layout_marginTop="2dp"/>

                        <!-- Progress bar -->
                        <ProgressBar
                            android:id="@+id/progressMisiMingguan"
                            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                            android:layout_width="match_parent"
                            android:layout_height="10dp"
                            android:layout_marginTop="8dp"
                            android:max="5"
                            android:progress="0"
                            android:progressDrawable="@drawable/bg_progress_drawable"/>

                        <TextView
                            android:id="@+id/tvProgressMisiMingguan"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0/5 misi selesai"
                            android:textSize="11sp"
                            android:textColor="@color/text_hint"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnClaimMingguan"
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:text="Klaim"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textAllCaps="false"
                        app:cornerRadius="24dp"
                        android:backgroundTint="@color/sunny_yellow"
                        android:visibility="gone"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Misi Spesial -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🌟 Misi Spesial"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp"
                android:layout_marginStart="4dp"/>

            <androidx.cardview.widget.CardView
                android:id="@+id/cardMisiSpesial"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="28dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="@color/soft_purple_light">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="20dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:text="🌟"
                        android:textSize="32sp"
                        android:gravity="center"
                        android:background="@drawable/circle_menu_purple"
                        android:elevation="4dp"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Juara Digital!"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/soft_purple"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Selesaikan semua kuis!"
                            android:textSize="12sp"
                            android:textColor="@color/text_secondary"
                            android:layout_marginTop="2dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Hadiah: +200 poin 🏅"
                            android:textSize="12sp"
                            android:textColor="@color/soft_purple"
                            android:textStyle="bold"
                            android:layout_marginTop="4dp"/>

                        <TextView
                            android:id="@+id/tvStatusSpesial"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Lvl 3 &amp; 3 Badge"
                            android:textSize="11sp"
                            android:textColor="@color/text_hint"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnClaimSpesial"
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:text="Klaim"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textAllCaps="false"
                        app:cornerRadius="24dp"
                        android:backgroundTint="@color/soft_purple"
                        android:visibility="gone"/>

                    <TextView
                        android:id="@+id/tvIconSpesial"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="▶"
                        android:textSize="20sp"
                        android:textColor="@color/soft_purple"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:layout_gravity="bottom"
        android:background="@color/bg_card"
        app:menu="@menu/bottom_nav_menu"
        app:itemIconTint="@color/sky_blue"
        app:itemTextColor="@color/text_primary"
        app:labelVisibilityMode="labeled"
        android:elevation="16dp"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
