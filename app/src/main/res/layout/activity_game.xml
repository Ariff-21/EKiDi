<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/layoutHeader"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:background="@drawable/bg_splash_gradient"
        android:orientation="horizontal"
        android:padding="20dp"
        android:gravity="center_vertical">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@android:drawable/ic_menu_revert"
            android:background="@drawable/circle_settings_bg"
            android:padding="10dp"
            app:tint="#FFFFFF" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🕹️ Main Game"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_marginStart="16dp"/>

    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="85dp"
        android:padding="20dp"
        android:clipToPadding="false"
        android:paddingBottom="100dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Info Banner -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="28dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="@color/soft_purple_light">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="20dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🎮"
                        android:textSize="40sp"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Petualangan Seru!"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/soft_purple"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Ayo bantu karakter EKiDi melewati rintangan!"
                            android:textSize="13sp"
                            android:textColor="@color/text_secondary"
                            android:layout_marginTop="4dp"/>

                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Pilih Level -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pilih Tantanganmu 🏆"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="16dp"
                android:layout_marginStart="4dp"/>

            <!-- Level Mudah -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardLevelMudah"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="28dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/leaf_green_light">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:text="😊"
                        android:textSize="32sp"
                        android:gravity="center"
                        android:background="@drawable/circle_menu_green"
                        android:elevation="4dp"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Level Mudah"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/leaf_green"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Cocok untuk pemula!"
                            android:textSize="12sp"
                            android:textColor="@color/text_secondary"
                            android:layout_marginTop="2dp"/>

                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnMainMudah"
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:text="Main"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textAllCaps="false"
                        app:cornerRadius="24dp"
                        android:backgroundTint="@color/leaf_green"
                        android:layout_marginEnd="8dp"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Level Sedang -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardLevelSedang"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="28dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/sky_blue_light">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:text="🤔"
                        android:textSize="32sp"
                        android:gravity="center"
                        android:background="@drawable/circle_menu_blue"
                        android:elevation="4dp"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Level Sedang"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/sky_blue"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Lebih menantang!"
                            android:textSize="12sp"
                            android:textColor="@color/text_secondary"
                            android:layout_marginTop="2dp"/>

                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnMainSedang"
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:text="Main"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textAllCaps="false"
                        app:cornerRadius="24dp"
                        android:backgroundTint="@color/sky_blue"
                        android:layout_marginEnd="8dp"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Level Sulit -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardLevelSulit"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="28dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/sunny_yellow_light">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:text="😤"
                        android:textSize="32sp"
                        android:gravity="center"
                        android:background="@drawable/circle_menu_yellow"
                        android:elevation="4dp"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Level Sulit"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/sunny_yellow"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Kamu pasti bisa!"
                            android:textSize="12sp"
                            android:textColor="@color/text_secondary"
                            android:layout_marginTop="2dp"/>

                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnMainSulit"
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:text="Main"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textAllCaps="false"
                        app:cornerRadius="24dp"
                        android:backgroundTint="@color/sunny_yellow"
                        android:layout_marginEnd="8dp"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Navigation -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:layout_gravity="bottom"
        android:background="@color/bg_card"
        app:menu="@menu/bottom_nav_menu"
        app:itemIconTint="@color/sky_blue"
        app:itemTextColor="@color/text_primary"
        app:labelVisibilityMode="labeled"
        android:elevation="16dp"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
